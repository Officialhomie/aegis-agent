# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.md
!README.md
!**/SKILL.md
!docs/**/*.md
!openclaw-skill/**/*.md
!openclaw-skills-PR-ready/**/*.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Secrets & environment (never commit real values) ---
.env*
!.env.example
!.env*.example

# Filled Railway/Vercel scratch templates (safe example is railway-env-template.example.txt)
railway-env-template.txt

# vercel
.vercel
vercel-env-template.txt

# Keys, keystores, and signing material
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.p12
*.pfx
*.keystore

# Nested git repos (e.g. accidental clones under skills bundles)
openclaw-skills-PR-ready/.git/
openclaw-skills-PR-ready/**/.git/

# IDE / agent session dirs (may reference local paths or keys)
.claude/
.cursor/

# Local logs and on-chain build artifacts
agent.log
broadcast/
cache/

# typescript
*.tsbuildinfo
next-env.d.ts
