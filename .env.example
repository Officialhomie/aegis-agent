# Aegis Agent - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# REQUIRED = must be set for the feature to work
# OPTIONAL = has a default or feature works without it

# ============================================
# DATABASE
# ============================================
# REQUIRED for memory and identity (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/aegis"

# ============================================
# AI SERVICES
# ============================================

# OPTIONAL: OpenAI API Key (for GPT-4 reasoning; required if not using Claude)
OPENAI_API_KEY="sk-..."

# OPTIONAL: Anthropic API Key (for Claude reasoning)
ANTHROPIC_API_KEY="sk-ant-..."

# OPTIONAL: Use Claude for reasoning instead of OpenAI
USE_CLAUDE_REASONING="false"
# OPTIONAL: Override reasoning models
OPENAI_REASONING_MODEL="gpt-4-turbo"
ANTHROPIC_REASONING_MODEL="claude-sonnet-4-20250514"

# Skills executor (hybrid: guards + LLM). Enforced mode uses skill verdict in policy.
SKILLS_ENFORCED="false"
SKILLS_FAIL_CLOSED="true"
SKILLS_LLM_MODEL="openai:gpt-4o-mini"
SKILLS_GAS_REJECT_GWEI="200"
SKILLS_COST_REJECT_USD="100"

# Pinecone Vector Database (for long-term memory)
PINECONE_API_KEY="..."
PINECONE_ENVIRONMENT="us-east-1"
PINECONE_INDEX_NAME="aegis-memory"

# ============================================
# BLOCKCHAIN RPC ENDPOINTS
# ============================================

# Base (primary chain for AgentKit)
RPC_URL_BASE="https://base-mainnet.g.alchemy.com/v2/YOUR_KEY"
RPC_URL_BASE_SEPOLIA="https://base-sepolia.g.alchemy.com/v2/YOUR_KEY"

# ============================================
# FOUNDRY KEYSTORE (Recommended - secure agent wallet)
# ============================================
# Agent wallet: load from encrypted keystore (no private key in .env)
KEYSTORE_ACCOUNT="deployer-onetruehomie"
KEYSTORE_PASSWORD="your-keystore-password"
# Or set CAST_PASSWORD (cast CLI uses this when non-interactive)
# To create: cast wallet import aegis-agent --interactive (enter key + password)
# Verify: cast wallet address --account aegis-agent

# ============================================
# FOUNDRY KEYSTORE (Deployment only)
# ============================================
FOUNDRY_ACCOUNT="deployer-onetruehmie"
# To create: cast wallet import deployer-onetruehmie --interactive

# ============================================
# CONTRACT DEPLOYMENT
# ============================================
# OR: Raw private key (less secure, for CI/testing only)
DEPLOYER_PRIVATE_KEY=""
# Agent wallet that will call ActivityLogger (required for deployment)
# Also used by IDENTITY / paymaster - set in AGENT_WALLET_ADDRESS below if shared
# Basescan API key for contract verification (optional; enables --verify on deploy)
BASESCAN_API_KEY=""

# === Deployed Contract Addresses (set after deployment) ===
# Set after: npm run deploy:activity-logger
ACTIVITY_LOGGER_ADDRESS=""
# Set after: ./scripts/deploy-attestation-logger.sh (Base mainnet)
ATTESTATION_LOGGER_ADDRESS=""
# Set after: npm run deploy:delegation-registry (Base mainnet)
DELEGATION_REGISTRY_ADDRESS=""

# ============================================
# METAMASK DELEGATION FRAMEWORK (MDF)
# ============================================
# DelegationManager contract address for Base Sepolia (testnet)
MDF_DELEGATION_MANAGER_ADDRESS_BASE_SEPOLIA=""
# Base mainnet — MUST be this exact name (code reads MDF_DELEGATION_MANAGER_ADDRESS_BASE, not _BASE_MAINNET)
MDF_DELEGATION_MANAGER_ADDRESS_BASE=""
# Optional override used by resolveDelegationManagerAddress() when set
MDF_DELEGATION_MANAGER_ADDRESS=""
# Signing script: npm run sign:mdf-delegation
MDF_DELEGATE_ADDRESS=""
MDF_DELEGATOR_PRIVATE_KEY=""
# Caveat enforcer addresses (Base Sepolia) — names must match src/lib/mdf/constants.ts (MDF_ENFORCER_*)
MDF_ENFORCER_ALLOWED_TARGETS_BASE_SEPOLIA=""
MDF_ENFORCER_ALLOWED_METHODS_BASE_SEPOLIA=""
MDF_ENFORCER_TIMESTAMP_BASE_SEPOLIA=""
MDF_ENFORCER_VALUE_LTE_BASE_SEPOLIA=""
MDF_ENFORCER_NONCE_BASE_SEPOLIA=""
MDF_ENFORCER_ERC20_TRANSFER_BASE_SEPOLIA=""

# Set after: npm run deploy:reactive-observer
REACTIVE_OBSERVER_ADDRESS=""
# Set after: npm run deploy:paymaster
AEGIS_PAYMASTER_ADDRESS=""

# ============================================
# AEGIS PAYMASTER (sovereign ERC-4337 paymaster)
# ============================================
# REQUIRED when AEGIS_PAYMASTER_ADDRESS is set.
# Dedicated ECDSA key that signs every paymaster approval (never reuse the agent wallet key).
# Generate: cast wallet new  →  copy the private key and its public address
AEGIS_PAYMASTER_SIGNING_KEY=""
# Public address of the signing key above (used in deploy:paymaster)
AEGIS_PAYMASTER_SIGNING_KEY_ADDRESS=""
# OPTIONAL: How long each signed approval is valid in milliseconds (default: 300000 = 5 min)
PAYMASTER_APPROVAL_DURATION_MS="300000"

# ============================================
# SOVEREIGN PAYMASTER — LIVE MODE BYPASS
# ============================================
# When AEGIS_PAYMASTER_ADDRESS + AEGIS_PAYMASTER_SIGNING_KEY are both set,
# canExecuteSponsorship() returns { mode: 'LIVE' } immediately for any non-suspended
# protocol — no CDP allowlist approval required. Aegis owns the paymaster contract
# and signs its own approvals on-chain.
#
# Deploy:  npm run deploy:paymaster   (prints AEGIS_PAYMASTER_ADDRESS)
# Fund:    npm run fund:paymaster     (deposits 0.05 ETH into EntryPoint)
#
# Demo / testnet overrides (safe to set in CI / staging only):
# Skip historical tx check for fresh demo wallets:
SKIP_LEGITIMACY_CHECK=""
# Lower reserve requirement for testnet wallets (default: 0.05 ETH):
RESERVE_THRESHOLD_ETH=""
# Allow protocol budget top-up without onchain USDC proof:
ALLOW_LEGACY_TOPUP=""

# Ethereum
RPC_URL_ETHEREUM="https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY"
RPC_URL_SEPOLIA="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"

# ============================================
# AGENT CONFIGURATION
# ============================================

# Decision thresholds
AGENT_CONFIDENCE_THRESHOLD="0.75"

# Safety limits
MAX_TRANSACTION_VALUE_USD="10000"
MAX_GAS_PRICE_GWEI="100"

# Execution mode: "LIVE" | "SIMULATION" | "READONLY"
AGENT_EXECUTION_MODE="SIMULATION"

# OPTIONAL: Comma-separated chain IDs for observe (default: 84532)
SUPPORTED_CHAINS="84532,8453"

# OPTIONAL: Network for AgentKit (e.g. base-sepolia)
AGENT_NETWORK_ID="base-sepolia"

# ============================================
# API AUTHENTICATION (REQUIRED for production)
# ============================================

# Bearer token for /api/agent/cycle, /api/agent/status, /api/reactive/event
AEGIS_API_KEY="your-secure-api-key-here"

# ============================================
# X402 PAYMENT RAILS
# ============================================

# x402 Configuration
X402_ENABLED="true"
X402_MIN_PAYMENT_USD="1"

# x402 Payment Verification (REQUIRED for paid actions)
# Without X402_FACILITATOR_URL, payment verification is disabled and paid actions are rejected.
X402_FACILITATOR_URL="https://x402.org/facilitator"
X402_API_KEY="your-x402-api-key"
# OPTIONAL: Execution mode for paid actions (default: SIMULATION)
X402_EXECUTION_MODE="SIMULATION"
# OPTIONAL: Base fee per action in USDC (default: 0.001)
X402_BASE_FEE_USDC="0.001"
# OPTIONAL: Gas cost markup multiplier (default: 1.1)
X402_GAS_MARKUP="1.1"

# ============================================
# FARCASTER (Neynar - Base Paymaster)
# ============================================
# REQUIRED for posting sponsorship proofs to Farcaster
# Get API key at https://neynar.com; create signer via Neynar API for your Farcaster account
NEYNAR_API_KEY=""
FARCASTER_SIGNER_UUID=""
FARCASTER_FID=""

# ============================================
# MOLTBOOK (AI Agent Social Network)
# ============================================
# OPTIONAL: Moltbook API key (set after running npm run register:moltbook)
MOLTBOOK_API_KEY=""
# OPTIONAL: Heartbeat interval in ms (default: 4 hours)
MOLTBOOK_HEARTBEAT_INTERVAL="14400000"
# OPTIONAL: Submolt for posting treasury insights (default: general)
MOLTBOOK_SUBMOLT="general"

# ============================================
# REACTIVE NETWORK (REQUIRED for event-driven mode)
# ============================================

# HMAC secret for /api/reactive/event webhook signature verification
REACTIVE_CALLBACK_SECRET="your-hmac-secret-key"

# ============================================
# EAS Attestation (Gas Passport)
# ============================================
# Set after: npm run register:eas-schema (requires keystore + ETH for gas)
EAS_GAS_PASSPORT_SCHEMA_UID=""

# ============================================
# IDENTITY (ERC-8004 - Official Contracts)
# ============================================
# Network for ERC-8004: sepolia, mainnet, or base-sepolia (uses official addresses when not overridden)
ERC8004_NETWORK="sepolia"
# OPTIONAL: Override Identity Registry address (default: official address for ERC8004_NETWORK)
ERC8004_IDENTITY_REGISTRY_ADDRESS=""
# OPTIONAL: Override Reputation Registry address
ERC8004_REPUTATION_REGISTRY_ADDRESS=""
# OPTIONAL: RPC URL for ERC-8004 chain (defaults to RPC_URL_SEPOLIA if sepolia, RPC_URL_BASE_SEPOLIA if base-sepolia)
ERC8004_RPC_URL=""
# OPTIONAL: Agent wallet address (for registration and paymaster)
AGENT_WALLET_ADDRESS=""
# OPTIONAL: IPFS gateway for metadata upload (e.g. https://ipfs.infura.io:5001)
IPFS_GATEWAY_URL=""
# OPTIONAL: IPFS for decision JSON (Pinata: IPFS_API_KEY + IPFS_SECRET_API_KEY; Infura: IPFS_PROJECT_ID + IPFS_PROJECT_SECRET)
IPFS_API_KEY=""
IPFS_SECRET_API_KEY=""
IPFS_PROJECT_ID=""
IPFS_PROJECT_SECRET=""

# ============================================
# ORACLES (CoinGecko, Chainlink)
# ============================================
# OPTIONAL: CoinGecko Pro API key (higher rate limits)
COINGECKO_API_KEY=""
# OPTIONAL: Oracle cache TTL in ms (default 60000)
ORACLE_CACHE_TTL_MS="60000"
# OPTIONAL: Max oracle cache entries (default 500)
ORACLE_CACHE_MAX_ENTRIES="500"

# ============================================
# RATE LIMITER / CIRCUIT BREAKER
# ============================================
# OPTIONAL: Redis URL for persistent rate limiter and circuit breaker state
REDIS_URL=""

# ============================================
# OBSERVATION
# ============================================
# OPTIONAL: Blockscout API base URL for low-gas wallet discovery (e.g. https://base.blockscout.com)
BLOCKSCOUT_API_URL=""
# OPTIONAL: USDC contract address for agent reserve reading (Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913)
USDC_ADDRESS=""
# OPTIONAL: Treasury address to monitor
TREASURY_ADDRESS=""
# OPTIONAL: Known scam contract addresses (comma-separated) for contract-whitelist / abuse check
ABUSE_SCAM_CONTRACTS=""
# OPTIONAL: Governor contract per chain (GOVERNOR_ADDRESS_<CHAIN_ID>)
# GOVERNOR_ADDRESS_84532=""
# OPTIONAL: Voting token per chain (VOTING_TOKEN_ADDRESS_<CHAIN_ID>)
# VOTING_TOKEN_ADDRESS_84532=""

# ============================================
# BOTCHAN (onchain agent messaging on Base)
# ============================================
# OPTIONAL: Private key for posting to Botchan feeds (or reuse EXECUTE_WALLET_PRIVATE_KEY)
BOTCHAN_PRIVATE_KEY=""
# OPTIONAL: Feed name for outbound decision posts (default: aegis-sponsorships / aegis-reserves by context)
BOTCHAN_FEED_OUTBOUND="aegis-decisions"
# OPTIONAL: Feed name to poll for agent requests (default: aegis-requests)
BOTCHAN_FEED_INBOUND="aegis-requests"

# ============================================
# ENS (primary name on Base)
# ============================================
# OPTIONAL: ENS name to set as reverse record for agent wallet (e.g. aegis-paymaster.eth)
ENS_NAME=""

# ============================================
# DONATE_TO_CHARITY (Endaoment 501(c)(3) on Base)
# ============================================
# OPTIONAL: Comma-separated EINs allowed for donations (e.g. 27-1661997,11-1666852)
DONATE_ALLOWED_EINS=""
# OPTIONAL: Max donation per decision in USD (default: 100)
DONATE_MAX_USD="100"

# ============================================
# DEPLOY_TOKEN (Clanker on Base)
# ============================================
# OPTIONAL: Set to "true" to allow DEPLOY_TOKEN action (rate limit: 1/week)
DEPLOY_TOKEN_ALLOWED="false"

# ============================================
# ALERTS
# ============================================
# OPTIONAL: Slack incoming webhook URL for ALERT_HUMAN (SLACK_WEBHOOK_URL used by code)
SLACK_WEBHOOK_URL=""
# OPTIONAL: Generic webhook URL (e.g. PagerDuty, email service)
ALERT_WEBHOOK_URL=""
# OPTIONAL: Email to include in webhook payload
ALERT_EMAIL=""

# ============================================
# EXECUTE (contract calls)
# ============================================
# Prefer KEYSTORE_ACCOUNT + KEYSTORE_PASSWORD (see FOUNDRY KEYSTORE above). After verifying keystore works, remove or leave blank:
EXECUTE_WALLET_PRIVATE_KEY=""
AGENT_PRIVATE_KEY=""
# OPTIONAL: Comma-separated contract addresses allowed for EXECUTE
ALLOWED_CONTRACT_ADDRESSES=""
# ACTIVITY_LOGGER_ADDRESS and REACTIVE_OBSERVER_ADDRESS: set in CONTRACT DEPLOYMENT section above
# Bundler RPC endpoint (REQUIRED for LIVE mode sponsorship)
# Pimlico (Base Sepolia): https://api.pimlico.io/v2/84532/rpc?apikey=YOUR_KEY
# Pimlico (Base mainnet): https://api.pimlico.io/v2/8453/rpc?apikey=YOUR_KEY
BUNDLER_RPC_URL=""
# OPTIONAL: EntryPoint address — default is v0.7 (required by AegisPaymaster.sol)
# Override to 0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789 for EntryPoint v0.6 only
ENTRY_POINT_ADDRESS=""

# ============================================
# REPUTATION
# ============================================
# OPTIONAL: On-chain attestation contract address
REPUTATION_ATTESTATION_CONTRACT_ADDRESS=""

# ============================================
# LOGGING & MONITORING
# ============================================

# OPTIONAL: Log level "debug" | "info" | "warn" | "error"
LOG_LEVEL="info"

# OPTIONAL: External monitoring
SENTRY_DSN=""

# ============================================
# OPENCLAW EXPANDED FEATURES
# ============================================
# Enable expanded OpenClaw commands (CRUD for agents, protocols, guarantees, etc.)
# Default: false (disabled) - set to "true" to enable
OPENCLAW_EXPANDED="false"

# Rate limiting for OpenClaw commands
# Maximum commands per minute per session (default: 60)
OPENCLAW_RATE_LIMIT_PER_MINUTE="60"
# Maximum destructive commands (delete, revoke, disable) per hour per session (default: 5)
OPENCLAW_DESTRUCTIVE_LIMIT_PER_HOUR="5"
# Confirmation timeout for destructive operations in ms (default: 60000 = 1 minute)
OPENCLAW_CONFIRMATION_TIMEOUT_MS="60000"

# ============================================
# HEARTBEAT / LIVENESS MONITORING
# ============================================
# Enable heartbeat worker for agent liveness monitoring
# Default: false (disabled)
HEARTBEAT_ENABLED="false"
# How often the worker checks for due heartbeats in ms (default: 60000 = 1 minute)
HEARTBEAT_CHECK_INTERVAL_MS="60000"
# Default heartbeat interval for new schedules in ms (default: 900000 = 15 minutes)
HEARTBEAT_DEFAULT_INTERVAL_MS="900000"

# ============================================
# PUBLIC LANDING METRICS (/api/public/landing-metrics)
# ============================================
# OPTIONAL: Comma-separated chain IDs for "mainnet" aggregates (deposits + Execution rows).
# Default: 8453 (Base mainnet). Use e.g. "84532" for Sepolia-only marketing.
AEGIS_PUBLIC_MAINNET_CHAIN_IDS="8453"

# Dashboard cost panel: unit-cost estimates (optional). Avoided $ = (filter+template skips)×LLM rate.
AEGIS_EST_LLM_CALL_USD="0.002"
# Optional: Neynar estimated spend = used posts × this (when rate limiter returns usage)
AEGIS_EST_NEYNAR_POST_USD=""
